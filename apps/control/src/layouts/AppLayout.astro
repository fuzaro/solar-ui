---
import BaseLayout from './BaseLayout.astro';
import { ControlShell } from '../components/ControlShell.tsx';

export interface Props {
  title?: string;
}
const { title = 'Control Plane' } = Astro.props;
const pathname = Astro.url.pathname;
---
<BaseLayout title={title}>
  <ControlShell activeHref={pathname} title={title} client:load>
    <slot />
  </ControlShell>
</BaseLayout>
